#other units

unit.onager.name = [orange]Onager
unit.onager.description = Ein riesiger Panzer ausgerüstet mit einem zielsuchenden Raketenwerfer und mehreren kleineren Waffen. Spezialisiert auf die Zerstörung von Gebäuden aber schwächer im Kampf gegen Einheiten.

unit.sambuca.name = [orange]Sambuca
unit.sambuca.description = Ein kleiner Panzer, ausgerüstet mit einer kleinen Waffe. Spezialisiert auf Gebäudezerstörung aber etwas schwächer gegen Einheiten.

unit.scorpio.name = [orange]Scorpio
unit.scorpio.description = Ein Panzer ausgerüstet mit einer Railgun. Spezialisiert auf Belagerungen. Schwächer gegen Einheiten.

unit.springald.name = [orange]Springald
unit.springald.description = Ein großer Panzer ausgerüstet mit einem Raketenwerffer und kleinen Lasereinheiten. Glänzt in Belagerungen aber ist etwas schwächer gegen Einheiten.

unit.aestiva.name = [green]Aestiva
unit.aestiva.description = Eine große naval-Supporteinheit ausgerüstet mit einer Heil-Shotgun. Erschafft Alba.

unit.alba.name = [green]Alba
unit.alba.description = Eine kleine naval-Supporteinheit, welche mit nichts außer einem kleinen Regenerationsprojektor ausgerüstet ist.

unit.annax.name = [purple]Annax
unit.annax.description = Eine kleine Bodeneinheit welche mithilfe von zwei Schlackegewehren großen Schaden verursachen kann.

unit.apis.name = [orange]Apis
unit.apis.description = Eine kleine, laserbasierte Angriffseinheit.

unit.arnux.name = [orange]Arnux
unit.arnux.description = Eine schwere Navaleinheit ausgerüstet mit hochmodernen Waffen welche EMPs verursachen können.

unit.arvens.name = [green]Arvens
unit.arvens.description = Eine mittelgroße naval-Supporteinheit, welche über keine Waffen verfügt aber einen Heilprojektor besitzt. Erhöht das Bautempo von Einheiten in der Nähe.

unit.auratus.name = [purple]Auratus
unit.auratus.description = Eine große Bodeneinheit, die Elementarwaffen nutzt, um hohen Schaden zu verursachen.

unit.close-range.name = [orange]Alopex
unit.close-range.description = Eine extrem schnelle Einheit mit hohem Schaden aber dafür mit sehr niedrigen Lebenspunkten.

unit.kestrel.name = [orange]Kestrel
unit.kestrel.description = Eine schnelle aber fragile Einheit mit starken offensiven Waffen.

unit.lancer-drone.name = [orange]Areus
unit.lancer-drone.description = Eine kleine Drohne, die mit 2 kleinen Lancern ausgestattet ist.

unit.plant.name = [green]Setzling
unit.plant.description = Eine große Supporteinheit, die darauf spezialisiert ist zu Bauen und zu Heilen.

unit.sapling.name = [green]Sprößling
unit.sapling.description = Eine mittelgroße Supporteinheit, die darauf spezialisiert ist zu Bauen und zu Heilen.

unit.seed.name = [green]Samen
unit.seed.description = Eine kleine Supporteinheit, die darauf spezialisiert ist zu Bauen und zu Heilen.

unit.mela.name = [orange]Mela
unit.mela.description = Eine kleine Einheit ausgerüstet mit einfacher Bewaffnung.

unit.scofra.name = [purple]Scofra
unit.scofra.description = Eine mittelgroße Bodeneinheit, welche Öl und Feuer nutzt, um viel Schaden zu verursachen.

unit.procer.name = [orange]Procer
unit.procer.description = Ein mittelgroße Einheit gemacht für den Angriff.

unit.ducalis.name = [orange]Ducalis
unit.ducalis.description = Eine große Angriffseinheit ausgerüstet mit Raketenwerfern und Lasern.

unit.cromis.name = [orange]Cromis
unit.cromis.description = Eine mittelgroße naval-Angriffseinheit, welche mit fortgerschrittener, EMP-auslösender Bewaffnung ausgestattet ist.


#mothership type

unit.sps-strahl.name = [orange]Orbitale Angriffsplattform STRAHL
unit.sps-strahl.description = Eine große Einheit ausgestattet mit mehreren Lasern, die Gegner einfrieren.

unit.japonica.name = [orange]Japonica
unit.japonica.description = Eine große Navaleinheit, die mit vielen verschiedenen Offensivwaffen ausgestattet ist und Eineiten erschaffen kann.

unit.corax.name = [green]Corax
unit.corax.description = Eine Einheit ähnlich der Corvus Einheit aber mit verbesserten Waffensystemen.

unit.hive.name = [orange]HIVE
unit.hive.description = Eine riesige Einheit ausgestattet mit mehreren Lasern, die Gegner verbrennen.

unit.lycosid.name = [purple]Lycosid
unit.lycosid.description = Eine Einheit, welche sehr gut gepanzert ist und mit Elementarwaffen sowie einer großen Energiewaffe kämpft. Erschafft elementare Einheiten.

unit.altaic.name = [green]Altaic
unit.altaic.description = Eine riesige Supporteinheit mit mehreren heilenden und kugel-abwehrenden Waffen. Erschafft Oxynoe. Beschädigt und verlangsamt Gegner mit einem Energiefeld. Dieses Energiefeld visiert auch freundliche Blöcke und Einheiten and und heilt sie.


#cerberian

unit.cerberian-penumbra.description = Eine Einheit mit Technologie ähnlich der einer Antumbra Einheit von Serpulo aber die Hauptkanone shießt einen Laser statt normalen Kugeln.

unit.cerberian-curtulus.description = Eine Einheit mit einem Aussehen ähnlich dem der Arkyid Einehit aber die Hauptkanone shießt anstatt Artilleriekugeln Flüssigkeitenkugeln.

unit.cerberian-hexathelid.description = Eine Einheit ähnlich dem Atrax aber shießt mit Schrot-Schlackenkugeln.

unit.cerberian-behemoth.description = Eine riesige Einheit und Cerberos stolzeste Erfindung. Shießt mit einem gewaltigen Laser, riesigen Splittergeshossen, Laserbarragen und kleineren FLAK-Geschützen.

unit.cerberian-straggle.description = Eine cerberianische Version der Crawler Einheit.

unit.cerberian-bayonet.description = Eine stärkere Version der Dagger Einheit, welche typischerweise auf Serpulo aufzufinden ist.

unit.cerberian-veil.description = Wie die Eclipse Einheit aber anstatt Flak shießt diese Einheit mit Rakteten. Schießt außerdem mit einem stärkeren Laser.

unit.cerberian-spark.description = Eine Einheit änhlich der Flare Einehit von Serpulo aber mit verbesserter Bewaffnung.

unit.cerberian-citadel.description = Eine verbesserte Version der Fortress Einehit, welche von Cerbero stammt.

unit.cerberian-vista.description = Eine Einheit wie die Horizon Einheit aber wirft stärkere Bomben ab.

unit.cerberian-cudgel.description = Eine Einheit änhlich der Mace Einehit von Serpulo aber stärker. Shießt mit einer anderen Art Flammenwerfer.

unit.cerberian-kaiser.description = Eine Einheit inspiriert von der Reign Einehit von Serpulo aber mit verbesserter Technologie.

unit.cerberian-baton.description = Eine neu hergestellte Version der Scepter Einheit.

unit.cerberian-nephila.description = Wie die Spiroct Einheit aber stiehlt mehr Leben mithilfe von verbesserten schächenden Lasern.

unit.cerberian-setosus.description = Eine Toxopid-ähnliche Einheit. Die Sekundärkanonen schießen schwächende, lebenstehlende Laser statt normalen.

unit.cerberian-summit.description = Eine Einheit änhlich der Zenith Einheit aber die Raketenwerfer feuern Raketenbarragen statt einzelnen Raketen.



