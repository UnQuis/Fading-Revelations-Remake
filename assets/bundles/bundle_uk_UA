#item turrets

block.caats.name = CAATS
block.caats.description = Auch wenn der Name niedlich klingen mag... dies ist Cerberos stolzeste anti-luft Erfindung: Das Cerberian Anti Air Turret System.

block.missile-battery.name = Raketenbatteria
block.missile-battery.description = Entsendet ballistische Dronen, welche eine große Barrage zielsuchender Raketen abfeuern. Kann sich während dem Aufladen nicht drehen.

block.interitus.name = Interitus
